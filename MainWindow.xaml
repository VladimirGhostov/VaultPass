<Window x:Class="VaultPass.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VaultPass"
        mc:Ignorable="d"
        Title="VaultPass" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="./Fonts/Comic Sans MS Pixel.ttf#Comic Sans MS pixel rus eng"
        Icon="/Assets/icon.ico">

    <Window.Resources>
        <!-- Стили для кнопок в розовых тонах -->
        <Style x:Key="PinkButton" TargetType="Button">
            <Setter Property="Background" Value="#FFB6C1"/>
            <Setter Property="Foreground" Value="#4A2C2C"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#FF69B4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF69B4"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки удаления -->
        <Style x:Key="PinkDangerButton" TargetType="Button" BasedOn="{StaticResource PinkButton}">
            <Setter Property="Background" Value="#FFA07A"/>
            <Setter Property="BorderBrush" Value="#CD5C5C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CD5C5C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для полей ввода -->
        <Style x:Key="PinkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FFF5F5"/>
            <Setter Property="BorderBrush" Value="#FFB6C1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Foreground" Value="#4A2C2C"/>
        </Style>

        <!-- Стиль для подписей -->
        <Style x:Key="PinkLabel" TargetType="Label">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#C71585"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <!-- Фоновое изображение -->
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="images/your-background.png" Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Полупрозрачная подложка, чтобы текст читался -->
        <Border Background="#80FFFFFF" CornerRadius="15" Margin="10">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Заголовок -->
                    <RowDefinition Height="Auto"/>
                    <!-- Панель ввода -->
                    <RowDefinition Height="Auto"/>
                    <!-- Кнопки управления -->
                    <RowDefinition Height="Auto"/>
                    <!-- ПОИСК -->
                    <RowDefinition Height="*"/>
                    <!-- Таблица -->
                    <RowDefinition Height="Auto"/>
                    <!-- Статус -->
                </Grid.RowDefinitions>

                <!-- Заголовок с сердечками -->
                <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="❤️" FontSize="48" Foreground="#FF69B4" Margin="0,0,10,0"/>
                        <TextBlock Text="VaultPass" 
                   FontSize="48" 
                   FontWeight="Bold" 
                   Foreground="#FF1493"
                   VerticalAlignment="Center"/>
                        <TextBlock Text="❤️" FontSize="48" Foreground="#FF69B4" Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="❤️  ❤️  ❤️  ❤️  ❤️" 
               FontSize="20" 
               Foreground="#FFB6C1" 
               HorizontalAlignment="Center"
               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Панель ввода -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="ID:" Grid.Column="0" Style="{StaticResource PinkLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtId" Grid.Column="1" Style="{StaticResource PinkTextBox}" Margin="5"/>

                    <Label Content="Логин:" Grid.Column="2" Style="{StaticResource PinkLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtLogin" Grid.Column="3" Style="{StaticResource PinkTextBox}" Margin="5"/>

                    <Label Content="Пароль:" Grid.Column="4" Style="{StaticResource PinkLabel}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtPassword" Grid.Column="5" Style="{StaticResource PinkTextBox}" Margin="5"/>

                    <Button x:Name="BtnAdd" Grid.Column="6" Content="❤️ Добавить" Style="{StaticResource PinkButton}" Margin="5,0,0,0" Click="BtnAdd_Click"/>

                    <!-- Кнопка с эмодзи вместо текста -->
                    <Button x:Name="BtnGenerate" 
                            Grid.Column="7" 
                            Content="🔑" 
                            Style="{StaticResource PinkButton}" 
                            Margin="5,0,-10,0" 
                            Click="BtnGenerate_Click" 
                            FontSize="20" 
                            ToolTip="Сгенерировать пароль"/>
                </Grid>

                <!-- Панель кнопок управления -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Button x:Name="BtnRefresh" Content="🔄 Обновить" Style="{StaticResource PinkButton}" Margin="5" Click="BtnRefresh_Click"/>
                    <Button x:Name="BtnDelete" Content="💔 Удалить" Style="{StaticResource PinkDangerButton}" Margin="5" Click="BtnDelete_Click"/>
                    <Button x:Name="BtnClear" Content="Очистить поля" Style="{StaticResource PinkButton}" Margin="5" Click="BtnClear_Click"/>
                    <Button x:Name="BtnEdit" Content="✏️ Редактировать" Style="{StaticResource PinkButton}" Margin="5" Click="BtnEdit_Click"/>
                    <!-- Новые кнопки для бэкапа -->
                    <Button x:Name="BtnBackup" Content="💾 Бэкап" Style="{StaticResource PinkButton}" Margin="5" Click="BtnBackup_Click" ToolTip="Сохранить копию базы данных"/>
                    <Button x:Name="BtnRestore" Content="📂 Восстановить" Style="{StaticResource PinkButton}" Margin="5" Click="BtnRestore_Click" ToolTip="Загрузить бэкап"/>
                </StackPanel>

                <!-- Панель поиска -->
                <Border Grid.Row="3" Background="#FFF5F5" BorderBrush="#FFB6C1" BorderThickness="2" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="❤️ Поиск ❤️" Grid.Column="0" Style="{StaticResource PinkLabel}" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtSearch" Grid.Column="1" Style="{StaticResource PinkTextBox}" Margin="5" TextChanged="TxtSearch_TextChanged"/>
                        <Button x:Name="BtnClearSearch" Grid.Column="2" Content="✖" Style="{StaticResource PinkButton}" Margin="5,5,0,5" Click="BtnClearSearch_Click" ToolTip="Очистить поиск"/>
                    </Grid>
                </Border>

                <!-- Таблица данных -->
                <DataGrid x:Name="DataGridPasswords"
                          Grid.Row="4"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionUnit="FullRow"
                          Background="#FFF5F5"
                          BorderBrush="#FFB6C1"
                          BorderThickness="2"
                          RowHeight="40"
                          FontSize="14"
                          Foreground="#4A2C2C"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="#FFB6C1"
                          VerticalGridLinesBrush="#FFB6C1"
                          HeadersVisibility="Column"
                          FontFamily="Segoe UI"
                          AlternatingRowBackground="#FFE6E6"
                          AlternationCount="2"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          CanUserResizeColumns="True"
                          CanUserReorderColumns="False"
                          CanUserSortColumns="True"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          MouseDoubleClick="DataGridPasswords_MouseDoubleClick">

                    <DataGrid.Resources>
                        <!-- Стиль для заголовков колонок -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFB6C1"/>
                            <Setter Property="Foreground" Value="#4A2C2C"/>
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Height" Value="45"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="1,1,1,2"/>
                            <Setter Property="BorderBrush" Value="#FF69B4"/>
                        </Style>

                        <!-- Стиль для ячеек -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="Foreground" Value="#4A2C2C"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#FFB6C1"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FF69B4"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#FF1493"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!-- Стиль для строк -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Height" Value="40"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFE0F0"/>
                                    <Setter Property="BorderBrush" Value="#FF69B4"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FF69B4"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" 
                                            Binding="{Binding Id}" 
                                            Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Логин" 
                                            Binding="{Binding Login}" 
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Left"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="5,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Пароль" 
                                            Binding="{Binding Password}" 
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Left"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="5,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Статус с сердечком -->
                <TextBlock x:Name="TxtStatus" 
                           Grid.Row="5"
                           Text="❤️ Готов к работе ❤️" 
                           Foreground="#C71585"
                           FontSize="14"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>